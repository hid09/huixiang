# 回响后台管理系统 - 数据库配置
# 复制此文件为 .env 并填入实际配置

# ========== 数据库配置 ==========
# 数据库主机
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库用户名
DB_USER=echo_readonly
# 数据库密码
DB_PASSWORD=your-db-password
# 数据库名称
DB_NAME=echo_db

# ========== 应用配置 ==========
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
