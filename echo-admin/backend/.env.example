# 回响后台管理系统 - 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ========== 应用配置 ==========
APP_NAME=回响后台管理系统
APP_VERSION=1.0.0
DEBUG=false

# ========== JWT 配置 ==========
# JWT 密钥（生产环境请修改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production
# JWT 算法
ALGORITHM=HS256
# Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== 数据库配置 ==========
# 主数据库（存储管理员账号）
DATABASE_URL=sqlite:////app/data/echo_admin.db
# 回响数据库（只读，读取用户数据）
ECHO_DATABASE_URL=sqlite:////app/data/echo.db

# ========== CORS 配置 ==========
# 允许的前端域名
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://39.107.118.177:8080"]
