# 回响后台管理系统 - 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ========== 应用配置 ==========
APP_NAME=回响后台管理系统
APP_VERSION=1.0.0
DEBUG=false

# ========== JWT 配置 ==========
# JWT 密钥（生产环境请修改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production
# JWT 算法
ALGORITHM=HS256
# Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== 数据库配置 ==========
# 数据库主机
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库用户名（只读账号）
DB_USER=echo_readonly
# 数据库密码
DB_PASSWORD=your-db-password
# 数据库名称
DB_NAME=echo_db

# ========== CORS 配置 ==========
# 允许的前端域名（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://admin.echo-app.com
